{
  "name": "thinkex",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -s first -n web,zero \"pnpm dev:web\" \"pnpm dev:zero\"",
    "dev:web": "concurrently -k -s first -n next,ai \"pnpm dev:next\" \"pnpm dev:ai\"",
    "dev:next": "next dev",
    "dev:ai": "pnpm exec devtools",
    "dev:zero": "node scripts/dev-zero.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "tc": "tsgo --noEmit",
    "tc:tsc": "tsc --noEmit",
    "clean": "rm -rf .next out dist",
    "clean:all": "rm -rf .next out dist node_modules .pnpm-store && pnpm install",
    "analyze": "cross-env ANALYZE=true next build",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:setup": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "db:reset": "pnpm db:drop && pnpm db:push",
    "deps:check": "knip",
    "deps:update": "pnpm update --interactive",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "pnpm build && pnpm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
