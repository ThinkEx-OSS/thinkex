{
	"$schema": "https://mintlify.com/docs.json",
	"name": "ThinkEx",
	"description": "A workspace for source-heavy study, research, and creation.",
	"theme": "mint",
	"logo": {
		"light": "/assets/thinkex-logo-wordmark-light.svg",
		"dark": "/assets/thinkex-logo-wordmark-dark.svg",
		"href": "https://thinkex.app"
	},
	"favicon": "/assets/favicon.svg",
	"colors": {
		"primary": "#5C8BD6",
		"light": "#73BF7A",
		"dark": "#0A0D0D"
	},
	"icons": {
